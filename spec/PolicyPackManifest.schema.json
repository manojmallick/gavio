{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gavio.io/schema/PolicyPackManifest.v1.json",
  "title": "PolicyPackManifest",
  "description": "Reusable domain Policy Pack catalog manifest.",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "domain",
    "description",
    "compatibility",
    "defaultAction",
    "redactionStrategy",
    "auditLabels",
    "detectors"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "string", "const": "1.0" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "domain": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "compatibility": {
      "type": "object",
      "required": ["gavio"],
      "additionalProperties": false,
      "properties": {
        "gavio": { "type": "string", "minLength": 1 }
      }
    },
    "defaultAction": {
      "type": "string",
      "enum": ["allow", "flag", "redact", "mask", "hash", "block", "route", "require-approval"]
    },
    "redactionStrategy": {
      "type": "string",
      "enum": ["tokenize", "mask", "hash", "redact"]
    },
    "auditLabels": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "detectors": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "PolicyRule.v1.json" }
    },
    "signature": { "$ref": "PolicyPackSignature.v1.json" }
  }
}
