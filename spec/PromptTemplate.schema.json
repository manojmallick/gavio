{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gavio.io/schema/PromptTemplate.v1.json",
  "title": "PromptTemplate",
  "description": "Versioned prompt template registered in a Gavio Prompt Registry.",
  "type": "object",
  "required": ["id", "version", "messages"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/message" }
    },
    "requiredVariables": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "metadata": { "type": "object", "additionalProperties": true },
    "approval": { "$ref": "#/$defs/approval" }
  },
  "$defs": {
    "message": {
      "type": "object",
      "required": ["role", "content"],
      "properties": {
        "role": { "type": "string", "enum": ["system", "user", "assistant", "tool"] },
        "content": { "type": "string" }
      },
      "additionalProperties": true
    },
    "approval": {
      "type": "object",
      "description": "Human approval metadata for this prompt template version.",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["draft", "pending", "approved", "rejected", "deprecated"]
        },
        "approvedBy": { "type": "string" },
        "approvedAt": { "type": "string", "format": "date-time" },
        "reviewers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "reason": { "type": "string" },
        "metadata": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": false
    }
  }
}
