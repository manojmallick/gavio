{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gavio.dev/spec/IntegrationAdapterPayload.schema.json",
  "title": "Gavio Integration Adapter Payload",
  "type": "object",
  "required": ["schemaVersion", "adapter", "target", "kind", "payload"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "gavio.integration-adapter.v1"
    },
    "adapter": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "target": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "gateway",
        "gateway_observability",
        "observability",
        "eval",
        "framework",
        "provider_sdk"
      ]
    },
    "payload": {
      "type": "object",
      "description": "Dependency-light payload fragment shaped for the target ecosystem tool.",
      "additionalProperties": true
    }
  }
}
