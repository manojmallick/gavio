{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gavio.io/schema/ToolDefinition.v1.json",
  "title": "ToolDefinition",
  "description": "Registry entry describing a governed tool available to an application runtime.",
  "type": "object",
  "required": ["name"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "input_schema": { "type": "object", "additionalProperties": true },
    "inputSchema": { "type": "object", "additionalProperties": true },
    "output_schema": { "type": "object", "additionalProperties": true },
    "outputSchema": { "type": "object", "additionalProperties": true },
    "permissions": {
      "type": "array",
      "items": { "$ref": "./ToolPermission.schema.json" },
      "uniqueItems": true
    },
    "risk": { "type": "string", "enum": ["low", "medium", "high", "critical", "destructive"] },
    "requires_approval": { "type": "boolean" },
    "requiresApproval": { "type": "boolean" },
    "freshness_ttl_seconds": { "type": "number", "minimum": 0 },
    "freshnessTtlSeconds": { "type": "number", "minimum": 0 },
    "provenance_required": { "type": "boolean" },
    "provenanceRequired": { "type": "boolean" },
    "mcp": { "$ref": "#/$defs/mcp" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true,
  "$defs": {
    "mcp": {
      "type": "object",
      "properties": {
        "server": { "type": "string" },
        "tool": { "type": "string" },
        "resource": { "type": "string" },
        "session_id": { "type": "string" },
        "sessionId": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
