{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gavio.dev/schemas/ProductionTrustBundle.v1.json",
  "title": "ProductionTrustBundle",
  "description": "Metadata-only production release evidence bundle for audit, runtime, policy, eval, benchmark, and architecture review.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bundleId",
    "generatedAt",
    "sdk",
    "release",
    "runtime",
    "privacy",
    "evidence",
    "documents",
    "bundleHash"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sdk": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": ["version"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "commit": { "type": "string" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": true,
      "required": ["environment", "policySource", "eventExportMode"],
      "properties": {
        "environment": { "type": "string", "minLength": 1 },
        "policySource": { "type": "string", "minLength": 1 },
        "controlPlaneEnabled": { "type": "boolean" },
        "eventExportMode": {
          "type": "string",
          "enum": ["metadata_only", "full_local_debug"]
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": true,
      "required": ["contentMode", "containsRawContent", "redactedFields"],
      "properties": {
        "contentMode": { "const": "metadata_only" },
        "containsRawContent": { "const": false },
        "redactedFields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["auditChain", "runtimeEvents", "controls"],
      "properties": {
        "auditChain": {
          "type": "object",
          "additionalProperties": false,
          "required": ["recordCount", "verified", "headHash", "tailHash"],
          "properties": {
            "recordCount": { "type": "integer", "minimum": 0 },
            "verified": { "type": "boolean" },
            "headHash": { "type": "string" },
            "tailHash": { "type": "string" }
          }
        },
        "runtimeEvents": {
          "type": "object",
          "additionalProperties": false,
          "required": ["eventCount", "contentFree", "eventTypes"],
          "properties": {
            "eventCount": { "type": "integer", "minimum": 0 },
            "contentFree": { "type": "boolean" },
            "eventTypes": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "controls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["type", "id", "status", "source"],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "policy_pack",
                  "eval_suite",
                  "benchmark",
                  "reference_architecture",
                  "control_plane",
                  "release_gate",
                  "other"
                ]
              },
              "id": { "type": "string", "minLength": 1 },
              "status": {
                "type": "string",
                "enum": ["pass", "warn", "fail", "not_applicable"]
              },
              "source": { "type": "string", "minLength": 1 },
              "sha256": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              }
            }
          }
        }
      }
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "path"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          }
        }
      }
    },
    "bundleHash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
