{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gavio.io/schema/PromptManifest.v1.json",
  "title": "PromptManifest",
  "description": "File-backed Prompt Registry manifest with semantic template versions and deterministic signature metadata.",
  "type": "object",
  "required": ["schemaVersion", "registryId", "templates"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gavio.prompt-registry.v2"
    },
    "registryId": { "type": "string", "minLength": 1 },
    "metadata": { "type": "object", "additionalProperties": true },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "allOf": [
          { "$ref": "./PromptTemplate.schema.json" },
          {
            "type": "object",
            "properties": {
              "version": {
                "type": "string",
                "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
              }
            }
          }
        ]
      }
    },
    "signature": {
      "type": "object",
      "required": ["algorithm", "keyId", "value"],
      "properties": {
        "algorithm": { "type": "string", "const": "HMAC-SHA256" },
        "keyId": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
