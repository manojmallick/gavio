{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gavio.io/schema/GavioRequest.v1.json",
  "title": "GavioRequest",
  "description": "The canonical, provider-agnostic request model. Field names are camelCase on the wire; Python binds them to snake_case (agent_id, parent_trace_id, ...).",
  "type": "object",
  "required": ["messages", "model", "provider"],
  "properties": {
    "traceId": {
      "type": "string",
      "description": "UUID v7 (time-sortable). Assigned automatically if omitted."
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/message" }
    },
    "model": { "type": "string", "minLength": 1 },
    "provider": { "$ref": "#/$defs/provider" },
    "agentId": { "type": ["string", "null"] },
    "parentTraceId": {
      "type": ["string", "null"],
      "description": "Links calls into a multi-agent DAG."
    },
    "sessionId": { "type": ["string", "null"] },
    "options": {
      "type": "object",
      "properties": {
        "temperature": { "type": "number" },
        "maxTokens": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "metadata": { "type": "object", "additionalProperties": true },
    "lineage": {
      "anyOf": [{ "$ref": "#/$defs/promptLineage" }, { "type": "null" }],
      "description": "Prompt provenance (F-OBS-04): template, variable bindings, and RAG chunk sources. Copied into the AuditRecord."
    }
  },
  "$defs": {
    "promptLineage": {
      "type": "object",
      "description": "Provenance for a rendered prompt. RAG chunk text is never stored — only source references.",
      "properties": {
        "templateId": { "type": ["string", "null"] },
        "templateVersion": { "type": ["string", "null"] },
        "variables": { "type": "object", "additionalProperties": true },
        "ragChunks": { "type": "array", "items": { "$ref": "#/$defs/ragChunk" } }
      },
      "additionalProperties": false
    },
    "ragChunk": {
      "type": "object",
      "description": "A reference to a retrieved source — never the retrieved text.",
      "required": ["source"],
      "properties": {
        "source": { "type": "string" },
        "chunkId": { "type": ["string", "null"] },
        "score": { "type": ["number", "null"] }
      },
      "additionalProperties": false
    },
    "message": {
      "type": "object",
      "required": ["role", "content"],
      "properties": {
        "role": { "type": "string", "enum": ["system", "user", "assistant", "tool"] },
        "content": { "type": "string" }
      },
      "additionalProperties": true
    },
    "provider": {
      "type": "string",
      "enum": ["openai", "anthropic", "gemini", "azure_openai", "ollama", "bedrock", "cohere", "mock"]
    }
  }
}
