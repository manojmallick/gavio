<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>io.github.manojmallick</groupId>
  <artifactId>gavio-parent</artifactId>
  <version>1.8.0</version>
  <packaging>pom</packaging>

  <name>Gavio Java SDK (parent)</name>
  <description>Local-first AI request runtime and inspector with PII guard, audit, reliability, prompt evals and pluggable providers.</description>
  <url>https://manojmallick.github.io/gavio</url>

  <licenses>
    <license>
      <name>MIT License</name>
      <url>https://opensource.org/licenses/MIT</url>
      <distribution>repo</distribution>
    </license>
  </licenses>

  <developers>
    <developer>
      <id>manojmallick</id>
      <name>Manoj Mallick</name>
      <url>https://github.com/manojmallick</url>
    </developer>
  </developers>

  <scm>
    <connection>scm:git:https://github.com/manojmallick/gavio.git</connection>
    <developerConnection>scm:git:ssh://git@github.com/manojmallick/gavio.git</developerConnection>
    <url>https://github.com/manojmallick/gavio</url>
    <tag>HEAD</tag>
  </scm>

  <modules>
    <module>gavio-core</module>
    <module>gavio-interceptor-pii</module>
    <module>gavio-interceptor-audit</module>
    <module>gavio-interceptor-reliability</module>
    <module>gavio-interceptor-cache</module>
    <module>gavio-interceptor-governance</module>
    <module>gavio-interceptor-guardrails</module>
    <module>gavio-interceptor-metrics</module>
    <module>gavio-interceptor-quality</module>
    <module>gavio-provider-openai</module>
    <module>gavio-provider-anthropic</module>
    <module>gavio-provider-gemini</module>
    <module>gavio-provider-azure</module>
    <module>gavio-provider-openrouter</module>
    <module>gavio-provider-ollama</module>
    <module>gavio-testing</module>
  </modules>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.release>17</maven.compiler.release>
    <junit.version>5.10.2</junit.version>
    <surefire.version>3.2.5</surefire.version>
    <compiler.version>3.13.0</compiler.version>
  </properties>

  <dependencyManagement>
    <dependencies>
      <dependency>
        <groupId>org.junit</groupId>
        <artifactId>junit-bom</artifactId>
        <version>${junit.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
      <!-- Internal modules -->
      <dependency>
        <groupId>io.github.manojmallick</groupId>
        <artifactId>gavio-core</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.manojmallick</groupId>
        <artifactId>gavio-interceptor-pii</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.manojmallick</groupId>
        <artifactId>gavio-interceptor-audit</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.manojmallick</groupId>
        <artifactId>gavio-interceptor-reliability</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.manojmallick</groupId>
        <artifactId>gavio-interceptor-cache</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.manojmallick</groupId>
        <artifactId>gavio-interceptor-governance</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.manojmallick</groupId>
        <artifactId>gavio-interceptor-guardrails</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.manojmallick</groupId>
        <artifactId>gavio-interceptor-metrics</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.manojmallick</groupId>
        <artifactId>gavio-interceptor-quality</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.manojmallick</groupId>
        <artifactId>gavio-provider-openai</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.manojmallick</groupId>
        <artifactId>gavio-provider-anthropic</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.manojmallick</groupId>
        <artifactId>gavio-provider-openrouter</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.github.manojmallick</groupId>
        <artifactId>gavio-testing</artifactId>
        <version>${project.version}</version>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <dependencies>
    <!-- Test dependencies shared by every module. -->
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <pluginManagement>
      <plugins>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-compiler-plugin</artifactId>
          <version>${compiler.version}</version>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-surefire-plugin</artifactId>
          <version>${surefire.version}</version>
        </plugin>
      </plugins>
    </pluginManagement>
  </build>

  <profiles>
    <!--
      Activated only during release (mvn -Prelease deploy). Attaches sources +
      javadoc jars, signs everything with GPG, and publishes to Maven Central
      via the Sonatype Central Portal. Normal builds/tests never sign.
    -->
    <profile>
      <id>release</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-source-plugin</artifactId>
            <version>3.3.1</version>
            <executions>
              <execution>
                <id>attach-sources</id>
                <goals><goal>jar-no-fork</goal></goals>
              </execution>
            </executions>
          </plugin>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-javadoc-plugin</artifactId>
            <version>3.7.0</version>
            <configuration>
              <doclint>none</doclint>
              <failOnError>false</failOnError>
            </configuration>
            <executions>
              <execution>
                <id>attach-javadocs</id>
                <goals><goal>jar</goal></goals>
              </execution>
            </executions>
          </plugin>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-gpg-plugin</artifactId>
            <version>3.2.4</version>
            <executions>
              <execution>
                <id>sign-artifacts</id>
                <phase>verify</phase>
                <goals><goal>sign</goal></goals>
              </execution>
            </executions>
            <configuration>
              <!-- Non-interactive signing in CI (passphrase via env). -->
              <gpgArguments>
                <arg>--pinentry-mode</arg>
                <arg>loopback</arg>
              </gpgArguments>
            </configuration>
          </plugin>
          <plugin>
            <groupId>org.sonatype.central</groupId>
            <artifactId>central-publishing-maven-plugin</artifactId>
            <version>0.10.0</version>
            <extensions>true</extensions>
            <configuration>
              <!-- server-id 'central' is configured by setup-java in CI. -->
              <publishingServerId>central</publishingServerId>
              <autoPublish>true</autoPublish>
              <!-- Wait only for validation (bounded), not full publish. Central
                   auto-publishes after; 'published' can hang for a long time on
                   a first-time namespace and stall the CI job. -->
              <waitUntil>validated</waitUntil>
            </configuration>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>
</project>
