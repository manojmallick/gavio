{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping the Gavio metrics endpoint (F-OBS-08)",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Gavio Gateway",
  "uid": "gavio-gateway",
  "description": "Fleet observability for the Gavio AI gateway — request rate, latency, token throughput, cost burn, and cache savings from the F-OBS-08 Prometheus metrics. LLM-semantic views (PII diffs, agent DAGs, cache near-misses, hash-chain verification) live in the Gavio Inspector, not here.",
  "tags": ["gavio", "llm", "ai-gateway"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "provider",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(gavio_requests_total, provider)",
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(gavio_requests_total{provider=~\"$provider\"}, model)",
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (provider, model) (rate(gavio_requests_total{provider=~\"$provider\", model=~\"$model\"}[5m]))",
          "legendFormat": "{{provider}}/{{model}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (ms)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(gavio_request_latency_ms_bucket{provider=~\"$provider\", model=~\"$model\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gavio_request_latency_ms_bucket{provider=~\"$provider\", model=~\"$model\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(gavio_request_latency_ms_bucket{provider=~\"$provider\", model=~\"$model\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Token throughput (tokens/s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (kind) (rate(gavio_tokens_total{provider=~\"$provider\", model=~\"$model\"}[5m]))",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cost burn (USD/h)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (provider, model) (rate(gavio_cost_usd_total{provider=~\"$provider\", model=~\"$model\"}[5m])) * 3600",
          "legendFormat": "{{provider}}/{{model}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Cache hit rate",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } },
      "targets": [
        {
          "expr": "sum(rate(gavio_cache_hits_total{provider=~\"$provider\", model=~\"$model\"}[1h])) / sum(rate(gavio_requests_total{provider=~\"$provider\", model=~\"$model\"}[1h]))"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Requests (24h)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum(increase(gavio_requests_total{provider=~\"$provider\", model=~\"$model\"}[24h]))"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Cost (24h, USD)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [
        {
          "expr": "sum(increase(gavio_cost_usd_total{provider=~\"$provider\", model=~\"$model\"}[24h]))"
        }
      ]
    }
  ]
}
